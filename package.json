{
  "name": "chisto-mk",
  "version": "0.1.0",
  "private": true,
  "description": "Chisto.mk — Civic environmental platform for pollution reporting and cleanup",
  "scripts": {
    "dev": "pnpm -r --parallel --filter '!@chisto/mobile' run dev",
    "dev:api": "pnpm --filter @chisto/api dev",
    "dev:admin": "pnpm --filter @chisto/admin dev",
    "dev:landing": "pnpm --filter @chisto/landing dev",
    "dev:mobile": "pnpm --filter @chisto/mobile dev",
    "build": "pnpm -r --workspace-concurrency=1 --filter '!@chisto/mobile' run build",
    "build:api": "pnpm --filter @chisto/api build",
    "build:admin": "pnpm --filter @chisto/admin build",
    "build:landing": "pnpm --filter @chisto/landing build",
    "build:mobile": "pnpm --filter @chisto/mobile build",
    "db:generate": "pnpm --filter @chisto/api exec prisma generate",
    "db:migrate": "pnpm --filter @chisto/api exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @chisto/api exec prisma migrate deploy",
    "db:migrate:status": "pnpm --filter @chisto/api exec prisma migrate status",
    "db:push": "pnpm --filter @chisto/api exec prisma db push",
    "db:studio": "pnpm --filter @chisto/api exec prisma studio",
    "ci:check": "pnpm --filter @chisto/api exec prisma generate && pnpm --filter @chisto/api exec prisma validate && pnpm build",
    "lint": "pnpm -r --filter '!@chisto/mobile' run lint",
    "test": "pnpm -r --filter '!@chisto/mobile' run test",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "overrides": {
      "handlebars": "4.7.9",
      "protobufjs": "7.5.5",
      "axios": "1.16.0",
      "follow-redirects": "1.15.11",
      "path-to-regexp@0.1.12": "0.1.13",
      "multer": "2.1.1",
      "serialize-javascript": "7.0.5",
      "fast-uri": "3.1.2",
      "picomatch": "4.0.3",
      "defu": "6.1.7",
      "lodash": "4.18.1",
      "@nestjs/common": "10.4.22",
      "@nestjs/core": "10.4.22",
      "node-emoji": "2.2.0",
      "effect": "3.21.2",
      "fast-xml-parser": "5.8.0"
    }
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
