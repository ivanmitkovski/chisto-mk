# Chisto.mk — Staging environment template
# Do not commit real staging credentials.

DATABASE_URL="postgresql://<user>:<password>@<staging-host>:5432/chisto_staging"
PORT=3000
JWT_SECRET="replace-with-staging-secret"
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_DAYS=30

# Optional cloud configuration
AWS_REGION="<region>"
S3_BUCKET_NAME="<bucket-name>"
