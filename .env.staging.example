# Chisto.mk — Staging environment template
# Do not commit real staging credentials. Staging enforces the SAME boot-time gates as production
# (validateEnv() treats 'staging' like 'production'); a missing REQUIRED var will process.exit(1).

# ---------------------------------------------------------------------------
# Core (REQUIRED)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://<user>:<password>@<staging-host>:5432/chisto_staging?sslmode=require"
PORT=3000
NODE_ENV=staging

# JWT (REQUIRED). Secret must be >= 32 chars in staging.
JWT_SECRET="replace-with-staging-secret-min-32-chars"
# During secret rotation, set the prior secret so in-flight access tokens keep validating.
# JWT_SECRET_PREVIOUS="prior-staging-secret"
# JWT_KID=default
# JWT_KID_PREVIOUS=previous
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_DAYS=90
JWT_REFRESH_STANDARD_DAYS=7
REFRESH_TOKEN_ROTATION_GRACE_SECONDS=120
MAX_SESSIONS_PER_USER=20

# CORS (REQUIRED). Admin dashboard origin for invite/moderation deep links (REQUIRED).
CORS_ORIGINS=https://admin-staging.chisto.mk
ADMIN_APP_BASE_URL=https://admin-staging.chisto.mk

# ---------------------------------------------------------------------------
# HMAC / encryption secrets (REQUIRED)
# ---------------------------------------------------------------------------
CHECK_IN_QR_SECRET="replace-with-staging-checkin-secret-min-24"
SITE_SHARE_TOKEN_SECRET="replace-with-staging-share-secret-min-24"
# SITE_SHARE_FINGERPRINT_SECRET="replace-with-staging-fingerprint-secret-min-24"
# Exactly 64 hex chars (32 bytes). node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHAT_ENCRYPTION_KEY="replace-with-64-hex-char-key"
SHARE_BASE_URL=https://staging.chisto.mk

# ---------------------------------------------------------------------------
# Redis / ElastiCache (REQUIRED)
# ---------------------------------------------------------------------------
REDIS_URL=rediss://<staging-redis-host>:6379
# REDIS_TLS=true

# ---------------------------------------------------------------------------
# Metrics (REQUIRED) — protects GET /metrics
# ---------------------------------------------------------------------------
METRICS_BEARER_TOKEN="replace-with-staging-metrics-bearer-token"

# ---------------------------------------------------------------------------
# SMS / Twilio (REQUIRED — phone OTP + password-reset SMS)
# ---------------------------------------------------------------------------
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="replace-with-twilio-auth-token"
TWILIO_WEBHOOK_BASE_URL=https://api-staging.chisto.mk
# Provide AT LEAST ONE sender path:
TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_PHONE_NUMBER=+38970000000
# TWILIO_ALPHANUMERIC_SENDER=ChistoMK

# ---------------------------------------------------------------------------
# Storage / S3 (REQUIRED for media uploads). Prefer ECS task role.
# ---------------------------------------------------------------------------
S3_BUCKET_NAME=chisto-staging-media
AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Push / FCM (REQUIRED when PUSH_FCM_ENABLED=true)
# ---------------------------------------------------------------------------
PUSH_FCM_ENABLED=true
FIREBASE_SERVICE_ACCOUNT_JSON=
NOTIFICATIONS_INBOX_ENABLED=true

# ---------------------------------------------------------------------------
# Transactional email / Postmark (REQUIRED when EMAIL_ENABLED=true)
# ---------------------------------------------------------------------------
EMAIL_ENABLED=true
POSTMARK_SERVER_TOKEN="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
POSTMARK_WEBHOOK_BASIC_USER="postmark-webhook"
POSTMARK_WEBHOOK_BASIC_PASS="replace-with-staging-webhook-pass"
EMAIL_FROM_NAME=Chisto.mk
EMAIL_PUBLIC_API_BASE_URL=https://api-staging.chisto.mk
EMAIL_APP_BASE_URL=https://staging.chisto.mk

# ---------------------------------------------------------------------------
# Networking / observability (recommended)
# ---------------------------------------------------------------------------
# TRUSTED_PROXY_CIDRS=10.0.0.0/16
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05
# LOG_LEVEL=info
GEOIP_ENABLED=false
