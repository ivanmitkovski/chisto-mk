# Chisto.mk — Production environment template
# Do not commit real production credentials. Inject secrets via AWS Secrets Manager → ECS task `secrets`.
# Every var marked REQUIRED is enforced at boot by validateEnv() (apps/api/src/config/env.ts);
# the API process.exit(1)s on startup if a required prod var is missing/invalid.

# ---------------------------------------------------------------------------
# Core (REQUIRED)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://<user>:<password>@<prod-host>:5432/chisto_prod?sslmode=require"
PORT=3000
NODE_ENV=production

# JWT (REQUIRED). Secret must be >= 32 chars in production.
JWT_SECRET="replace-with-production-secret-min-32-chars"
# During secret rotation, set the prior secret so in-flight access tokens keep validating.
# JWT_SECRET_PREVIOUS="prior-production-secret"
# JWT_KID=default
# JWT_KID_PREVIOUS=previous
# Access token TTL in seconds. 900=15min (3600=1h, 28800=8h).
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_DAYS=90
JWT_REFRESH_STANDARD_DAYS=7
REFRESH_TOKEN_ROTATION_GRACE_SECONDS=120
MAX_SESSIONS_PER_USER=20

# CORS (REQUIRED in production). Admin origins allowed for browser calls.
CORS_ORIGINS=https://admin.chisto.mk
# Socket.IO CORS (REQUIRED in production). Comma-separated allowlist for /chat, /notifications, /reports-owner, /check-in.
CHAT_WS_CORS_ORIGINS=https://admin.chisto.mk,https://chisto.mk
# Admin dashboard origin for invite emails and moderation deep links (REQUIRED).
ADMIN_APP_BASE_URL=https://admin.chisto.mk

# ---------------------------------------------------------------------------
# HMAC / encryption secrets (REQUIRED in production)
# ---------------------------------------------------------------------------
# Event check-in QR HMAC (>= 24 chars).
CHECK_IN_QR_SECRET="replace-with-prod-checkin-secret-min-24"
# Signed site-share link HMAC (>= 24 chars).
SITE_SHARE_TOKEN_SECRET="replace-with-prod-share-secret-min-24"
# Optional dedicated share-attribution pseudonymization secret (>= 24 chars). Falls back to SITE_SHARE_TOKEN_SECRET if unset.
# SITE_SHARE_FINGERPRINT_SECRET="replace-with-prod-fingerprint-secret-min-24"
# Event chat encryption key: exactly 64 hex chars (32 bytes). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: rotating this key makes previously stored chat messages undecryptable.
CHAT_ENCRYPTION_KEY="replace-with-64-hex-char-key"
# Public share host base URL (no trailing slash).
SHARE_BASE_URL=https://chisto.mk

# ---------------------------------------------------------------------------
# Redis / ElastiCache (REQUIRED in production for inbox/outbox + multi-task realtime)
# ---------------------------------------------------------------------------
# Use rediss:// for in-transit TLS, or redis:// with REDIS_TLS=true.
REDIS_URL=rediss://<prod-redis-host>:6379
# REDIS_TLS=true
# Never set REDIS_TLS_REJECT_UNAUTHORIZED=0 in production.

# ---------------------------------------------------------------------------
# Metrics (REQUIRED in production) — protects GET /metrics
# ---------------------------------------------------------------------------
METRICS_BEARER_TOKEN="replace-with-prod-metrics-bearer-token"

# ---------------------------------------------------------------------------
# SMS / Twilio (REQUIRED in production — phone OTP + password-reset SMS)
# ---------------------------------------------------------------------------
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="replace-with-twilio-auth-token"
# Public base URL of this API (no path) for Twilio status-callback signature validation (REQUIRED in prod).
TWILIO_WEBHOOK_BASE_URL=https://api.chisto.mk
# Provide AT LEAST ONE sender path:
# Messaging Service SID (MG + 32 hex) — preferred.
TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# E.164 long code (ignored when Messaging Service SID is set).
# TWILIO_PHONE_NUMBER=+38970000000
# Alphanumeric sender label (country rules apply).
# TWILIO_ALPHANUMERIC_SENDER=ChistoMK

# ---------------------------------------------------------------------------
# Storage / S3 (REQUIRED for media uploads). Prefer ECS task role over static keys.
# ---------------------------------------------------------------------------
S3_BUCKET_NAME=chisto-prod-media
AWS_REGION=eu-central-1
# Only if NOT using an ECS task role (not recommended):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# REPORT_MEDIA_SIGNED_URL_TTL_SECONDS=900

# ---------------------------------------------------------------------------
# Push / FCM (REQUIRED when PUSH_FCM_ENABLED=true)
# ---------------------------------------------------------------------------
# Set PUSH_FCM_ENABLED=true and provide FIREBASE_SERVICE_ACCOUNT_JSON to deliver push notifications.
PUSH_FCM_ENABLED=true
# Firebase Admin service account JSON as a single line. Use the PRODUCTION Firebase project.
FIREBASE_SERVICE_ACCOUNT_JSON=
NOTIFICATIONS_INBOX_ENABLED=true

# ---------------------------------------------------------------------------
# Transactional email / Postmark (REQUIRED when EMAIL_ENABLED=true)
# ---------------------------------------------------------------------------
EMAIL_ENABLED=true
POSTMARK_SERVER_TOKEN="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
POSTMARK_WEBHOOK_BASIC_USER="postmark-webhook"
POSTMARK_WEBHOOK_BASIC_PASS="replace-with-prod-webhook-pass"
# Optional Postmark inbound webhook signature secret.
# POSTMARK_WEBHOOK_SECRET=
EMAIL_FROM_NAME=Chisto.mk
# EMAIL_FROM_ADDRESS=no-reply@chisto.mk
EMAIL_PUBLIC_API_BASE_URL=https://api.chisto.mk
EMAIL_APP_BASE_URL=https://chisto.mk
# EMAIL_LOGO_URL=https://www.chisto.mk/brand/logo.png
# PASSWORD_RESET_URL=https://chisto.mk/reset-password

# ---------------------------------------------------------------------------
# Networking / observability (recommended)
# ---------------------------------------------------------------------------
# Comma-separated CIDRs of the ALB/proxy so X-Forwarded-For is trusted (anti-spoofing for throttle/geo).
# TRUSTED_PROXY_CIDRS=10.0.0.0/16
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05  (REQUIRED when SENTRY_DSN is set)
# SENTRY_RELEASE=
# LOG_LEVEL=info
# Coarse geo-IP for admin active-users. Keep disabled unless a commercial HTTPS geo provider is configured.
GEOIP_ENABLED=false
