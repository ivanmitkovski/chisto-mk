# Chisto.mk — Production environment template
# Do not commit real production credentials.

DATABASE_URL="postgresql://<user>:<password>@<prod-host>:5432/chisto_prod"
PORT=3000
JWT_SECRET="replace-with-production-secret"
# Admin origins allowed for CORS (required in production/staging)
CORS_ORIGINS=https://admin.chisto.mk
# Access token TTL in seconds. 900=15min. Increase for less frequent re-auth (e.g. 3600=1h, 28800=8h).
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_DAYS=30

# Optional cloud configuration
AWS_REGION="<region>"
S3_BUCKET_NAME="<bucket-name>"
