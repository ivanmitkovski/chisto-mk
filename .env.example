# Chisto.mk — Local environment template
# For local dev, copy to .env.
# For staging/prod templates, see .env.staging.example / .env.production.example.

# Database (used by API)
DATABASE_URL="postgresql://chisto:chisto@localhost:5432/chisto"

# API
PORT=3000
JWT_SECRET="replace-with-long-random-secret"
# During secret rotation, set the prior secret so in-flight access tokens keep validating.
# JWT_SECRET_PREVIOUS="prior-local-secret"
# JWT_KID=default
# JWT_KID_PREVIOUS=previous
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_DAYS=90
JWT_REFRESH_STANDARD_DAYS=7
REFRESH_TOKEN_ROTATION_GRACE_SECONDS=120
MAX_SESSIONS_PER_USER=20

# Notifications / Push (API)
NOTIFICATIONS_INBOX_ENABLED=true
PUSH_FCM_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_JSON=""
