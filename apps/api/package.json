{
  "name": "@chisto/api",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --coverageReporters=text-summary --passWithNoTests",
    "test:cov:leaks": "jest --coverage --coverageReporters=text-summary --passWithNoTests --detectOpenHandles --runInBand",
    "test:cov:areas": "node scripts/check-coverage-areas.mjs",
    "check:god-services": "node scripts/check-no-god-services.mjs",
    "audit:high": "node scripts/audit-api-deps.mjs",
    "perf:baseline:check": "node scripts/check-k6-baseline.mjs",
    "check:cycles": "madge --circular --extensions ts ./src/main.ts",
    "snapshot:openapi": "node scripts/snapshot-openapi-run.cjs",
    "snapshot:openapi:check": "node scripts/snapshot-openapi-run.cjs --check",
    "test:e2e": "jest --config test/e2e/jest-e2e.config.js --runInBand",
    "test:e2e:local": "bash scripts/run-e2e-local.sh",
    "perf:smoke": "k6 run perf/smoke.js",
    "perf:load": "k6 run perf/k6-load-test.js",
    "feed:simulate": "tsx scripts/feed-v2-simulation.ts",
    "seed": "tsx prisma/seed.ts",
    "db:resolve:report-title": "prisma migrate resolve --applied 20260326190001_add_report_title",
    "db:migrate:status": "prisma migrate status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@chisto/map-contracts": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^10",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "@sentry/node": "^10.52.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "image-size": "^2.0.2",
    "ioredis": "^5.10.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "onnxruntime-node": "^1.24.3",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/image-size": "^0.8.0",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1"
  }
}
