{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "generated/**/*",
      { "include": "email/templates/**/*.hbs", "watchAssets": true },
      { "include": "auth/quiz/**/*.json", "watchAssets": true }
    ]
  }
}
