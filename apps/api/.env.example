DATABASE_URL=
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_DAYS=7
MAX_SESSIONS_PER_USER=5
CORS_ORIGINS=
PORT=3000
NODE_ENV=development

# --- Load balancer (ALB / reverse proxy) ---
# REST uses /events/*; Socket.IO uses /socket.io/* on the SAME host (namespace /chat).
# Forward both path prefixes to this API. Path rules that only match /events* will break chat WebSockets.
# Smoke test: GET /socket.io/?EIO=4&transport=polling should return an Engine.IO handshake (not 404).
# Keep ALB idle timeout >= 60s for long-lived SSE and WebSocket connections.

# HMAC secret for event check-in QR tokens (>= 24 chars). Required in production.
CHECK_IN_QR_SECRET=
SMS_PROVIDER=none
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# S3 for report photo uploads
S3_BUCKET_NAME=
AWS_REGION=
# Optional: only when not using an ECS/EKS IAM role. On ECS, prefer a task role and omit these.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Notifications / Push
NOTIFICATIONS_INBOX_ENABLED=true
PUSH_FCM_ENABLED=false
# JSON string for Firebase Admin service account (single-line escaped JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional if the API always runs as a single instance (e.g. ECS desired count = 1).
# Required before scaling to 2+ tasks: event chat SSE + Socket.IO Redis adapter + pub/sub fan-out.
# Without Redis on multi-instance, clients on different tasks miss each other's live updates.
# Use ElastiCache in the same VPC. Startup logs: "Socket.IO Redis adapter enabled" and
# "Event chat Redis fanout enabled".
REDIS_URL=
# ElastiCache in-transit TLS: use rediss:// in REDIS_URL, or redis:// with REDIS_TLS=true.
# Set REDIS_TLS_REJECT_UNAUTHORIZED=0 only for dev if you must skip TLS cert verification.
# REDIS_TLS=
# REDIS_TLS_REJECT_UNAUTHORIZED=

# Chat encryption: 32-byte key as 64 hex chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If empty, chat messages are stored in plaintext.
CHAT_ENCRYPTION_KEY=

# When true or 1, list/search/pinned/send responses rewrite chat attachment URLs to short-lived S3 signed GETs (requires S3 IAM GetObject).
# CHAT_SIGNED_ATTACHMENT_URLS=true

# Comma-separated origins allowed for Socket.IO /chat (e.g. https://app.example.com). If unset: dev uses *; production reflects request Origin (tighter than *).
# CHAT_WS_CORS_ORIGINS=https://app.example.com

# Prisma migrate recovery (ECS/docker only): set for one deploy to fix drift, then unset.
# PRISMA_RESOLVE_APPLIED_MIGRATION=
# PRISMA_RESOLVE_ROLLED_BACK_MIGRATION=
