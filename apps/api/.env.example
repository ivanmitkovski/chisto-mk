# Append pool tuning when needed, e.g. ?connection_limit=10&pool_timeout=20 (see Prisma datasource URL docs).
# Optional Postgres safety: append `?statement_timeout=5000` (ms) to cap long statements at the pool.
DATABASE_URL=
# Optional: log Prisma queries slower than PRISMA_SLOW_QUERY_MS in production (adds listener; default 500).
# PRISMA_LOG_SLOW_QUERIES=1
# PRISMA_SLOW_QUERY_MS=500
# Optional: disable Postgres LISTEN/NOTIFY for outbox workers (default enabled outside NODE_ENV=test).
# PG_OUTBOX_LISTEN=false
# PG_OUTBOX_NOTIFY=false
JWT_SECRET=
# During secret rotation, set the prior secret so in-flight access tokens keep validating.
# JWT_SECRET_PREVIOUS=
# JWT_KID=default
# JWT_KID_PREVIOUS=previous
JWT_ACCESS_EXPIRES_IN=900
# Full refresh TTL for remember-me logins; mobile defaults rememberMe=true.
JWT_REFRESH_EXPIRES_DAYS=90
JWT_REFRESH_STANDARD_DAYS=7
REFRESH_TOKEN_ROTATION_GRACE_SECONDS=120
# Active device sessions per user (oldest revoked when exceeded). Align with auth-env default (20).
MAX_SESSIONS_PER_USER=20
CORS_ORIGINS=
# When true, enables Access-Control-Allow-Credentials (requires explicit CORS_ORIGINS allowlist).
CORS_ALLOW_CREDENTIALS=false
PORT=3000
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal (default: debug in dev, info in prod)
# LOG_LEVEL=info

# Sample rate for 4xx client-error warn logs in production (0–1, default 0.1)
# CLIENT_ERROR_LOG_SAMPLE_RATE=0.1

# --- Load balancer (ALB / reverse proxy) ---
# REST uses /events/*; Socket.IO uses /socket.io/* on the SAME host (namespace /chat).
# Forward both path prefixes to this API. Path rules that only match /events* will break chat WebSockets.
# Smoke test: GET /socket.io/?EIO=4&transport=polling should return an Engine.IO handshake (not 404).
# Keep ALB idle timeout >= 60s for long-lived SSE and WebSocket connections.

# Return OTP code in API responses (development only; default false). Never enable in staging/production.
# OTP_DEV_RETURN_CODE=false
# HMAC secret for event check-in QR tokens (>= 24 chars). Required in production/staging.
CHECK_IN_QR_SECRET=
# HMAC secret for signed site-share links (>= 24 chars). Required in production/staging.
SITE_SHARE_TOKEN_SECRET=
# Optional dedicated HMAC secret for share attribution pseudonymization (>= 24 chars).
# If empty in non-production, API falls back to SITE_SHARE_TOKEN_SECRET.
SITE_SHARE_FINGERPRINT_SECRET=
# Public share host base URL (no trailing slash), e.g. https://chisto.mk
SHARE_BASE_URL=https://chisto.mk
SMS_PROVIDER=none
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Messaging Service SID (MG + 32 hex) as `messaging_service_sid`, or any other value Twilio accepts as API `From` (e.g. alphanumeric label or sender SID).
TWILIO_MESSAGING_SERVICE_SID=
# E.164 long code. Ignored when TWILIO_MESSAGING_SERVICE_SID is set (including non-MG values used as `From`).
TWILIO_PHONE_NUMBER=
# Alphanumeric sender label (e.g. ChistoMK) as `from` when TWILIO_MESSAGING_SERVICE_SID is empty. Country rules apply in Twilio.
TWILIO_ALPHANUMERIC_SENDER=
# Public base URL of this API (no path). Used to build the status-callback URL for Twilio signature validation.
TWILIO_WEBHOOK_BASE_URL=https://api.chisto.mk

# S3 for report photo uploads
S3_BUCKET_NAME=
# Presigned GET TTL for report evidence thumbnails (seconds, 60–3600; default 900)
# REPORT_MEDIA_SIGNED_URL_TTL_SECONDS=900
AWS_REGION=
# Optional: S3-compatible endpoint (MinIO, LocalStack). When set, path-style URLs default on unless S3_FORCE_PATH_STYLE=false.
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true
# Optional: only when not using an ECS/EKS IAM role. On ECS, prefer a task role and omit these.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Notifications / Push
NOTIFICATIONS_INBOX_ENABLED=true
# Discovery feed: when false, GET /sites?scope=discovery falls back to strict local radius.
# FEED_DISCOVERY_ENABLED=true
# Set PUSH_FCM_ENABLED=true and provide FIREBASE_SERVICE_ACCOUNT_JSON to deliver push notifications.
PUSH_FCM_ENABLED=false
# Firebase Admin service account JSON as a single line, e.g. FIREBASE_SERVICE_ACCOUNT_JSON=$(jq -c . ./firebase-adminsdk.json)
# MUST be from the same Firebase project as the mobile app (google-services.json / GoogleService-Info.plist project_id).
# For iOS delivery upload APNs Auth Key (.p8) in Firebase Console → Project settings → Cloud Messaging.
# Debug/simulator builds use APNs sandbox and require a Development auth key; TestFlight/App Store use Production.
# Upload the same .p8 to both slots when using a token-based APNs key.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Transactional email (Postmark) ---
# Master switch; also requires FeatureFlag key `email_enabled` in DB (default false).
# EMAIL_ENABLED=false
# Required in production/staging when EMAIL_ENABLED=true
# POSTMARK_SERVER_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Postmark webhook HTTP Basic Auth (bounce/complaint → POST /webhooks/postmark)
# POSTMARK_WEBHOOK_BASIC_USER=
# POSTMARK_WEBHOOK_BASIC_PASS=
# From display name only; mailbox is always no-reply@chisto.mk
# EMAIL_FROM_NAME=Chisto.mk
# Public API base URL (no trailing slash) for unsubscribe links — e.g. https://api.chisto.mk
# EMAIL_PUBLIC_API_BASE_URL=
# Optional: where “manage preferences” should point (defaults to EMAIL_PUBLIC_API_BASE_URL or SHARE_BASE_URL)
# EMAIL_PREFERENCES_INFO_URL=https://chisto.mk/
# Optional: HTTPS origin for email CTA buttons. Falls back to SHARE_BASE_URL then https://chisto.mk
# EMAIL_APP_BASE_URL=https://chisto.mk
# PASSWORD_RESET_URL=https://chisto.mk/reset-password
# Admin invite accept-link base (no trailing slash). Required in production/staging.
# Also used for moderation email deep links (reports, events, UGC, risk signals).
ADMIN_APP_BASE_URL=https://admin.chisto.mk
# Invite link TTL in hours (default 72)
# ADMIN_INVITE_TTL_HOURS=72
# Optional: absolute HTTPS URL to logo image for HTML templates (must be publicly reachable)
# Optional override; default attaches bundled PNG inline (CID). Hosted fallback: https://www.chisto.mk/brand/logo.png
# EMAIL_LOGO_URL=https://www.chisto.mk/brand/logo.png

# Optional if the API always runs as a single instance (e.g. ECS desired count = 1).
# Required before scaling to 2+ tasks: auth refresh replay cache, event chat SSE,
# Socket.IO Redis adapter, and pub/sub fan-out. Without Redis on multi-instance,
# concurrent /auth/refresh may return INVALID_REFRESH_TOKEN and log mobile users out.
# Verify: GET /health/ready should report "redis":"ok" (not "skipped").
# Use ElastiCache in the same VPC. Startup logs: "Socket.IO Redis adapter enabled" and
# "Event chat Redis fanout enabled".
REDIS_URL=
# When true/1, pending QR confirmations require Redis (fail bootstrap if REDIS_URL missing).
# In production, Redis is always required for pending check-in even without this flag.
# CHECK_IN_REQUIRE_REDIS=true
# Organizer confirmation window for pending check-in (seconds, min 10). Redis key TTL matches.
# CHECK_IN_CONFIRM_TTL_SEC=60
# ElastiCache in-transit TLS: use rediss:// in REDIS_URL, or redis:// with REDIS_TLS=true.
# Set REDIS_TLS_REJECT_UNAUTHORIZED=0 only for dev if you must skip TLS cert verification.
# REDIS_TLS=
# REDIS_TLS_REJECT_UNAUTHORIZED=

# --- Event chat (REST + SSE + WebSocket /chat) ---
# REDIS_URL (above) is required for 2+ API tasks: chat uses Redis pub/sub channels `event-chat:<eventId>`
# for SSE fan-out across replicas, in addition to the Socket.IO Redis adapter when enabled.

# Chat encryption: 32-byte key as 64 hex chars. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If empty, chat messages are stored in plaintext.
CHAT_ENCRYPTION_KEY=

# When true or 1, list/search/pinned/send responses rewrite chat attachment URLs to short-lived S3 signed GETs (requires S3 IAM GetObject).
# CHAT_SIGNED_ATTACHMENT_URLS=true

# Comma-separated origins allowed for Socket.IO /chat (e.g. https://app.example.com). If unset: dev uses *; production reflects request Origin (tighter than *).
# CHAT_WS_CORS_ORIGINS=https://app.example.com

# Optional: CORS for Socket.IO /check-in namespace (falls back to CHAT_WS_CORS_ORIGINS then same rules as chat).
# CHECKIN_WS_CORS_ORIGINS=https://app.example.com

# Prisma migrate recovery (ECS/docker only): set for one deploy to fix drift, then unset.
# PRISMA_RESOLVE_APPLIED_MIGRATION=
# PRISMA_RESOLVE_ROLLED_BACK_MIGRATION=

# --- OpenTelemetry (optional) ---
# When OTEL_EXPORTER_OTLP_TRACES_ENDPOINT or OTEL_EXPORTER_OTLP_ENDPOINT is set, the API starts the Node SDK
# (HTTP + Prisma spans) before other modules load. Use with Grafana Tempo, Jaeger, Datadog Agent OTLP ingest, etc.
# OTEL_SERVICE_NAME=chisto-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# Optional auth for OTLP: OTEL_EXPORTER_OTLP_HEADERS=api-key=secret
# When OTLP tracing is on, set SENTRY_TRACES_SAMPLE_RATE=0 to avoid duplicate performance traces (keep Sentry for errors).

# --- Sentry ---
# SENTRY_DSN=
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.05

# --- Map feature flags (env; also see loadFeatureFlags in src/config/feature-flags.ts) ---
# MAP_ETAG_ENABLED=true
# MAP_SSE_ENABLED=true
# MAP_CACHE_ENABLED=true
# MAP_USE_PROJECTION=true
# MAP_POSTGIS_ENABLED=false
# MAP_TILE_FORMAT_VECTOR=false
# MAP_ADMIN_TIME_MACHINE=true

# Typesense map search (optional; Postgres full-text remains the fallback)
# MAP_SEARCH_TYPESENSE=false
# TYPESENSE_HOST=127.0.0.1
# TYPESENSE_PORT=8108
# TYPESENSE_PROTOCOL=http
# TYPESENSE_API_KEY=
# TYPESENSE_SITES_COLLECTION=map_sites
# TYPESENSE_CONNECTION_TIMEOUT_SECONDS=2
# TYPESENSE_SYNC_ENABLED=true
# Backfill: pnpm --filter @chisto/api run typesense:backfill

# Offline map region packages (S3-hosted .mbtiles / archives; mobile downloads via presigned URLs)
# MAP_OFFLINE_REGIONS=false
# MAP_OFFLINE_REGIONS_S3_PREFIX=map-offline/regions/
# MAP_OFFLINE_REGIONS_MANIFEST_S3_KEY=map-offline/regions/manifest.json
# MAP_OFFLINE_REGIONS_DOWNLOAD_TTL_SECONDS=3600
# Dev-only inline manifest (JSON array); production should use S3 manifest object
# MAP_OFFLINE_REGIONS_MANIFEST_JSON=[{"id":"mk-demo","label":"Demo","version":1,"checksumSha256":"abc","bounds":{"minLat":41,"maxLat":42,"minLng":20,"maxLng":22},"s3Key":"map-offline/regions/mk-demo-v1.mbtiles","updatedAt":"2026-01-01T00:00:00.000Z"}]

# --- Prometheus Pushgateway (optional) ---
# METRICS_PUSH_GATEWAY_URL=http://127.0.0.1:9091

# --- Supply chain (from monorepo root) ---
# Full tree: `pnpm audit`. API-scoped script (CI): `pnpm --filter @chisto/api run audit:high` with AUDIT_SEVERITY=critical then high.
# Stricter local check: AUDIT_SEVERITY=high pnpm --filter @chisto/api run audit:high
# Transitive fixes are centralized in the monorepo root `package.json` → `pnpm.overrides` (axios, lodash, path-to-regexp, multer, etc.); keep overrides minimal and remove when upstream releases land.
# Optional time-boxed advisory waivers: apps/api/scripts/audit-waivers.json (keep empty when possible).

# --- Metrics auth (REQUIRED in production/staging) ---
# Bearer token required to read GET /metrics in production/staging. Generate a long random token.
# METRICS_BEARER_TOKEN=

# --- Networking / proxy trust ---
# Comma-separated CIDRs of the ALB/reverse proxy. When set, X-Forwarded-For from these sources is
# trusted for client IP (throttling, geo). Leave unset to not trust forwarded IPs.
# TRUSTED_PROXY_CIDRS=10.0.0.0/16

# --- Auth (advanced) ---
# JWT clock skew tolerance in seconds (0–300, default 30).
# JWT_CLOCK_TOLERANCE_SECONDS=30

# --- Email (advanced) ---
# Optional explicit From mailbox (defaults to no-reply@chisto.mk). Must be a verified Postmark sender.
# EMAIL_FROM_ADDRESS=no-reply@chisto.mk
# Optional Postmark inbound webhook signature secret (in addition to Basic auth).
# POSTMARK_WEBHOOK_SECRET=

# --- Geo-IP (admin active-users) ---
# Coarse country/city from IP for the admin "active users" view. Default behaviour uses the free
# ip-api.com endpoint over HTTP — set to false unless a commercial HTTPS provider is wired in.
# GEOIP_ENABLED=false

# --- Discovery analytics (optional) ---
# DISCOVERY_ANALYTICS_ENABLED=false
# Shared secret required to POST discovery analytics ingest.
# DISCOVERY_ANALYTICS_INGEST_SECRET=

# --- Event chat tuning ---
# Push aggregation flush window in ms.
# EVENT_CHAT_PUSH_FLUSH_MS=
# Realtime socket push for notifications (DB FeatureFlag also applies).
# PUSH_REALTIME_SOCKET_ENABLED=

# --- Feed ranker (optional; defaults safe) ---
# FEED_V2_ENABLED=false
# FEED_V2_ONNX_ENABLED=false
# FEED_RANKER_ANTI_GAMING=
# FEED_RANKER_EXPLORATION=
# FEED_RANKER_SESSION_AFFINITY=

# --- Active-users / presence cron toggles (default enabled; set 'false' to disable) ---
# ACTIVE_USERS_CRON_ENABLED=false
# ACTIVITY_RETENTION_CRON_ENABLED=false
# ACTIVITY_RETENTION_DAYS=30
# ADMIN_ALERTS_ENABLED=false
# PRESENCE_ONLINE_WINDOW_MS=300000
# PRESENCE_TTL_MS=90000

# --- Map cron / worker toggles ---
# MAP_LIFECYCLE_CRON_ENABLED=false
# MAP_PROJECTION_WORKER_ENABLED=
# MAP_OTEL_LOG_SPANS=false
# MAP_STRICT_BOUNDS=false

# --- Request logging (debug) ---
# REQUEST_LOG_ALL_REQUESTS=false
# REQUEST_LOG_SKIP_PATHS=/health,/metrics

# --- Version / ops (injected by deploy; optional locally) ---
# GIT_SHA=
# APP_VERSION=
