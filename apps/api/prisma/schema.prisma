// Chisto.mk — Prisma schema
// Civic environmental platform: pollution reporting, site lifecycle, cleanup events

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  firstName    String
  lastName     String
  email        String   @unique
  phoneNumber  String   @unique
  passwordHash String
  role         Role     @default(USER)
  status       UserStatus @default(ACTIVE)
  isPhoneVerified Boolean @default(false)

  pointsBalance     Int @default(0)
  totalPointsEarned Int @default(0)
  totalPointsSpent  Int @default(0)
  reportCreditsAvailable Int @default(10)
  reportCreditsSpentTotal Int @default(0)
  reportEmergencyWindowDays Int @default(7)
  reportEmergencyUsedAt DateTime?
  lastActiveAt      DateTime?
  avatarObjectKey   String?
  avatarUpdatedAt   DateTime?

  totpSecret       String?   // Base32-encoded TOTP secret when 2FA enabled
  mfaBackupCodes   String[]  @default([]) // Hashed backup codes

  reports              Report[]             @relation("ReporterReports")
  moderatedReports     Report[]             @relation("ModeratorReports")
  adminNotifications   AdminNotification[]
  pointTransactions    PointTransaction[]
  coReportedReports    ReportCoReporter[]
  sessions             UserSession[]
  auditLogs            AuditLog[]
  adminTempTokens      AdminTempToken[]
  adminPendingMfa      AdminPendingMfa?
  siteVotes            SiteVote[]
  siteSaves            SiteSave[]
  siteComments         SiteComment[]
  siteShareEvents      SiteShareEvent[]
  siteCommentLikes     SiteCommentLike[]
  deviceTokens         UserDeviceToken[]
  userNotifications    UserNotification[]

  @@index([role])
  @@index([status])
}

model UserSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenId          String   @unique
  refreshTokenHash String
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PhoneOtp {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  phoneNumber  String
  code         String
  expiresAt    DateTime
  attemptCount Int      @default(0)

  @@unique([phoneNumber])
  @@index([expiresAt])
}

model LoginFailure {
  id             String   @id @default(cuid())
  phoneNumber    String   @unique
  firstFailedAt  DateTime
  attemptCount   Int

  @@index([phoneNumber])
}

model AdminLoginFailure {
  id             String   @id @default(cuid())
  email          String   @unique
  firstFailedAt  DateTime
  attemptCount   Int

  @@index([email])
}

model AdminTempToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tokenHash    String   @unique // bcrypt hash of the temp token
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String
  expiresAt    DateTime

  @@index([expiresAt])
  @@index([userId])
}

model AdminPendingMfa {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret    String
  expiresAt DateTime

  @@unique([userId])
  @@index([expiresAt])
}

enum Role {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// Admin notifications for console activity
model AdminNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  title     String
  message   String
  timeLabel String
  tone      AdminNotificationTone
  category  AdminNotificationCategory
  isUnread  Boolean @default(true)
  href      String?

  @@index([userId, createdAt])
  @@index([category, createdAt])
}

enum AdminNotificationTone {
  success
  warning
  info
  neutral
}

enum AdminNotificationCategory {
  reports
  system
  analytics
}

model PointTransaction {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  delta       Int
  balanceAfter Int
  reasonCode  String
  referenceType String?
  referenceId   String?
  metadata    Json?

  @@index([userId, createdAt])
  @@index([reasonCode])
}

enum ReportCleanupEffort {
  ONE_TO_TWO
  THREE_TO_FIVE
  SIX_TO_TEN
  TEN_PLUS
  NOT_SURE
}

// Canonical pollution/report site
model Site {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  latitude    Float
  longitude   Float
  /// Reverse-geocoded or user-confirmed place line from mobile (not the report narrative).
  address     String?
  description String?
  status      SiteStatus @default(REPORTED)
  upvotesCount Int       @default(0)
  commentsCount Int      @default(0)
  savesCount    Int      @default(0)
  sharesCount   Int      @default(0)

  reports     Report[]
  events      CleanupEvent[]
  votes       SiteVote[]
  saves       SiteSave[]
  comments    SiteComment[]
  shareEvents SiteShareEvent[]

  @@index([status])
  @@index([latitude, longitude])
  @@index([createdAt])
}

enum SiteStatus {
  REPORTED
  VERIFIED
  CLEANUP_SCHEDULED
  IN_PROGRESS
  CLEANED
  DISPUTED
}

// User-submitted pollution report
model Report {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  reportNumber String?  @unique // Human-friendly ID: CH-000001, set by DB trigger on insert

  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  reporterId String?
  reporter   User?    @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: SetNull)

  /// Short headline shown in lists and moderation (required on new submissions).
  title       String
  description String?
  mediaUrls   String[] @default([])
  category    String?
  severity    Int?
  cleanupEffort ReportCleanupEffort?

  status          ReportStatus @default(NEW)
  moderatedAt     DateTime?
  moderationReason String?
  moderatedById   String?
  moderatedBy     User?        @relation("ModeratorReports", fields: [moderatedById], references: [id], onDelete: SetNull)

  // Optional link to a primary report this one is considered a potential duplicate of
  potentialDuplicateOfId String?
  potentialDuplicateOf   Report? @relation("ReportPotentialDuplicate", fields: [potentialDuplicateOfId], references: [id])
  potentialDuplicates    Report[] @relation("ReportPotentialDuplicate")

  coReporters ReportCoReporter[]

  @@index([siteId])
  @@index([reporterId])
  @@index([status])
  @@index([potentialDuplicateOfId])
}

enum ReportStatus {
  NEW
  IN_REVIEW
  APPROVED
  DELETED
}

// Additional reporters attached to an existing report
model ReportCoReporter {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  reportId String
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reportId, userId])
  @@index([userId])
}

model SystemConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key   String @unique
  value String

  @@index([key])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key      String @unique
  enabled  Boolean @default(false)
  metadata Json?

  @@index([key])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorId      String?
  actor        User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?

  @@index([actorId, createdAt])
  @@index([resourceType, createdAt])
  @@index([action])
}

enum CleanupEventStatus {
  PENDING   // Awaiting admin approval (user-created)
  APPROVED  // Visible to users, can be joined
  DECLINED  // Rejected by admin
}

// Cleanup event at a site
model CleanupEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  scheduledAt DateTime
  completedAt DateTime?
  status      CleanupEventStatus @default(APPROVED) // PENDING when created by user, APPROVED by admin

  organizerId String?
  participantCount Int @default(0)

  @@index([siteId])
  @@index([scheduledAt])
  @@index([status])
}

model SiteVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([userId, createdAt])
  @@index([siteId, createdAt])
}

model SiteSave {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([userId, createdAt])
  @@index([siteId, createdAt])
}

model SiteComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parentId String?
  parent   SiteComment?  @relation("SiteCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  SiteComment[] @relation("SiteCommentReplies")
  likes    SiteCommentLike[]

  body      String
  isDeleted Boolean @default(false)
  likesCount Int    @default(0)

  @@index([siteId, createdAt])
  @@index([siteId, parentId, createdAt])
  @@index([authorId, createdAt])
}

model SiteCommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  commentId String
  comment   SiteComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, createdAt])
  @@index([userId, createdAt])
}

enum SiteShareChannel {
  native
  link
  whatsapp
  facebook
  x
  other
}

model SiteShareEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel SiteShareChannel @default(native)

  @@index([siteId, createdAt])
  @@index([userId, createdAt])
}

enum DevicePlatform {
  IOS
  ANDROID
}

model UserDeviceToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  platform     DevicePlatform
  appVersion   String?
  locale       String?
  lastSeenAt   DateTime @default(now())
  revokedAt    DateTime?
  failureCount Int      @default(0)

  @@index([userId, revokedAt])
  @@index([token])
}

enum NotificationType {
  SITE_UPDATE
  REPORT_STATUS
  UPVOTE
  COMMENT
  NEARBY_REPORT
  CLEANUP_EVENT
  SYSTEM
}

model UserNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title  String
  body   String
  type   NotificationType
  isRead Boolean @default(false)
  data   Json?
  sentAt DateTime?

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model NotificationOutbox {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userNotificationId String
  deviceToken        String
  payload            Json
  attempts           Int      @default(0)
  nextRetryAt        DateTime?
  processingAt       DateTime?
  leaseOwner         String?
  lastAttemptAt      DateTime?
  lastErrorCode      String?
  lastErrorMessage   String?
  deliveredAt        DateTime?
  failedPermanently  Boolean  @default(false)
  idempotencyKey     String   @unique

  @@index([deliveredAt, failedPermanently, attempts])
  @@index([processingAt, nextRetryAt])
  @@index([createdAt])
}
