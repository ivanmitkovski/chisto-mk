// Chisto.mk — Prisma schema
// Civic environmental platform: pollution reporting, site lifecycle, cleanup events

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName       String
  lastName        String
  email           String     @unique
  phoneNumber     String     @unique
  passwordHash    String
  role            Role       @default(USER)
  status          UserStatus @default(ACTIVE)
  isPhoneVerified Boolean    @default(false)

  pointsBalance             Int       @default(0)
  totalPointsEarned         Int       @default(0)
  totalPointsSpent          Int       @default(0)
  reportCreditsAvailable    Int       @default(10)
  reportCreditsSpentTotal   Int       @default(0)
  reportEmergencyWindowDays Int       @default(7)
  reportEmergencyUsedAt     DateTime?
  lastActiveAt              DateTime?
  avatarObjectKey           String?
  avatarUpdatedAt           DateTime?

  totpSecret     String? // Base32-encoded TOTP secret when 2FA enabled
  mfaBackupCodes String[] @default([]) // Hashed backup codes

  organizerCertifiedAt DateTime? // Set on organizer toolkit quiz pass; gates event creation

  reports                     Report[]                     @relation("ReporterReports")
  moderatedReports            Report[]                     @relation("ModeratorReports")
  adminNotifications          AdminNotification[]
  pointTransactions           PointTransaction[]
  coReportedReports           ReportCoReporter[]
  sessions                    UserSession[]
  auditLogs                   AuditLog[]
  adminTempTokens             AdminTempToken[]
  adminPendingMfa             AdminPendingMfa?
  siteVotes                   SiteVote[]
  siteSaves                   SiteSave[]
  siteComments                SiteComment[]
  siteShareEvents             SiteShareEvent[]
  siteShareLinks              SiteShareLink[]
  siteCommentLikes            SiteCommentLike[]
  feedState                   UserFeedState?
  feedImpressions             FeedImpression[]
  feedExperimentAssignments   FeedExperimentAssignment[]
  deviceTokens                UserDeviceToken[]
  userNotifications           UserNotification[]
  notificationPreferences     UserNotificationPreference[]
  organizedCleanupEvents      CleanupEvent[]               @relation("CleanupEventOrganizer")
  eventParticipations         EventParticipant[]
  eventCheckIns               EventCheckIn[]
  eventChatMessages           EventChatMessage[]           @relation("EventChatMessages")
  eventChatReadCursors        EventChatReadCursor[]        @relation("EventChatReadCursors")
  eventChatPinnedMessages     EventChatMessage[]           @relation("EventChatPinnedBy")
  eventChatMutes              EventChatMute[]              @relation("EventChatMutes")
  reportSubmitIdempotencyKeys ReportSubmitIdempotency[]
  eventEvidencePhotosUploaded EventEvidencePhoto[]
  routeSegmentsClaimed        EventRouteSegment[]          @relation("RouteSegmentClaims")
  checkInRiskSignals          CheckInRiskSignal[]

  @@index([role])
  @@index([status])
}

model UserSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenId          String    @unique
  refreshTokenHash String
  deviceInfo       String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PhoneOtp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  phoneNumber  String
  code         String
  expiresAt    DateTime
  attemptCount Int      @default(0)

  @@unique([phoneNumber])
  @@index([expiresAt])
}

model LoginFailure {
  id            String   @id @default(cuid())
  phoneNumber   String   @unique
  firstFailedAt DateTime
  attemptCount  Int

  @@index([phoneNumber])
}

model AdminLoginFailure {
  id            String   @id @default(cuid())
  email         String   @unique
  firstFailedAt DateTime
  attemptCount  Int

  @@index([email])
}

model AdminTempToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  tokenHash String   @unique // bcrypt hash of the temp token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  expiresAt DateTime

  @@index([expiresAt])
  @@index([userId])
}

model AdminPendingMfa {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  secret    String
  expiresAt DateTime

  @@unique([userId])
  @@index([expiresAt])
}

enum Role {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// Admin notifications for console activity
model AdminNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  title     String
  message   String
  timeLabel String
  tone      AdminNotificationTone
  category  AdminNotificationCategory
  isUnread  Boolean                   @default(true)
  href      String?

  /// Stable key for localized templates (e.g. `reports.submitted.new_site`). Title/message remain populated for legacy clients.
  messageTemplateKey    String?
  messageTemplateParams Json?

  @@index([userId, createdAt])
  @@index([category, createdAt])
}

enum AdminNotificationTone {
  success
  warning
  info
  neutral
}

enum AdminNotificationCategory {
  reports
  system
  analytics
}

model PointTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  delta         Int
  balanceAfter  Int
  reasonCode    String
  referenceType String @default("")
  referenceId   String @default("")
  metadata      Json?

  @@unique([userId, referenceType, referenceId, reasonCode], map: "point_transaction_user_ref_reason_key")
  @@index([userId, createdAt])
  @@index([reasonCode])
}

enum ReportCleanupEffort {
  ONE_TO_TWO
  THREE_TO_FIVE
  SIX_TO_TEN
  TEN_PLUS
  NOT_SURE
}

// Canonical pollution/report site
model Site {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  latitude      Float
  longitude     Float
  /// Reverse-geocoded or user-confirmed place line from mobile (not the report narrative).
  address       String?
  description   String?
  status        SiteStatus @default(REPORTED)
  upvotesCount  Int        @default(0)
  commentsCount Int        @default(0)
  savesCount    Int        @default(0)
  sharesCount   Int        @default(0)

  reports         Report[]
  events          CleanupEvent[]
  votes           SiteVote[]
  saves           SiteSave[]
  comments        SiteComment[]
  shareEvents     SiteShareEvent[]
  shareLinks      SiteShareLink[]
  featureSnapshot SiteFeatureSnapshot?
  feedImpressions FeedImpression[]

  @@index([status])
  @@index([latitude, longitude])
  /// Map queries often filter by status plus lat/lng bounding box.
  @@index([status, latitude, longitude])
  @@index([createdAt])
  /// Feed retrievers commonly filter by status and order by createdAt.
  @@index([status, createdAt])
  /// Engagement retriever ordering support.
  @@index([status, sharesCount, upvotesCount, commentsCount, createdAt])
}

enum SiteStatus {
  REPORTED
  VERIFIED
  CLEANUP_SCHEDULED
  IN_PROGRESS
  CLEANED
  DISPUTED
}

// User-submitted pollution report
model Report {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  reportNumber String?  @unique // Human-friendly ID: CH-000001, set by DB trigger on insert

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  reporterId String?
  reporter   User?   @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: SetNull)

  /// Short headline shown in lists and moderation (required on new submissions).
  title         String
  description   String?
  mediaUrls     String[]             @default([])
  category      String?
  severity      Int?
  cleanupEffort ReportCleanupEffort?

  status           ReportStatus @default(NEW)
  moderatedAt      DateTime?
  moderationReason String?
  moderatedById    String?
  moderatedBy      User?        @relation("ModeratorReports", fields: [moderatedById], references: [id], onDelete: SetNull)

  // Optional link to a primary report this one is considered a potential duplicate of
  potentialDuplicateOfId String?
  potentialDuplicateOf   Report?  @relation("ReportPotentialDuplicate", fields: [potentialDuplicateOfId], references: [id])
  potentialDuplicates    Report[] @relation("ReportPotentialDuplicate")

  /// Duplicate child reports merged into this canonical report (moderation merge).
  mergedDuplicateChildCount Int @default(0)

  coReporters           ReportCoReporter[]
  submitIdempotencyKeys ReportSubmitIdempotency[]

  @@index([siteId])
  @@index([reporterId])
  @@index([status])
  @@index([potentialDuplicateOfId])
}

enum ReportStatus {
  NEW
  IN_REVIEW
  APPROVED
  DELETED
}

// Additional reporters attached to an existing report
model ReportCoReporter {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  /// When this person filed their report (duplicate submission or merge source time).
  reportedAt DateTime

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reportId, userId])
  @@index([userId])
}

/// Client-supplied key (UUID) so duplicate POST /reports retries return the same report without double spend.
model ReportSubmitIdempotency {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  key      String
  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([createdAt])
}

/// Async-capable outbox for post-commit report side effects (merge notifications, audit, S3, WS).
enum ReportSideEffectKind {
  MERGE_DUPLICATE_POST
  MODERATION_STATUS_POST
}

enum ReportSideEffectStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ReportSideEffect {
  id          String                 @id @default(cuid())
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  kind        ReportSideEffectKind
  status      ReportSideEffectStatus @default(PENDING)
  payload     Json
  attempts    Int                    @default(0)
  lastError   String?
  processedAt DateTime?

  @@index([status, createdAt])
}

model SystemConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key   String @unique
  value String

  @@index([key])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  key      String  @unique
  enabled  Boolean @default(false)
  metadata Json?

  @@index([key])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorId      String?
  actor        User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ipAddress    String?

  @@index([actorId, createdAt])
  @@index([resourceType, createdAt])
  @@index([action])
}

enum CleanupEventStatus {
  PENDING // Awaiting admin approval (user-created)
  APPROVED // Visible to users, can be joined
  DECLINED // Rejected by admin
}

/// Citizen-facing lifecycle (aligned with mobile EcoEventStatus).
enum EcoEventLifecycleStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EcoEventCategory {
  GENERAL_CLEANUP
  RIVER_AND_LAKE
  TREE_AND_GREEN
  RECYCLING_DRIVE
  HAZARDOUS_REMOVAL
  AWARENESS_AND_EDUCATION
  OTHER
}

enum EcoCleanupScale {
  SMALL
  MEDIUM
  LARGE
  MASSIVE
}

enum EcoEventDifficulty {
  EASY
  MODERATE
  HARD
}

// Cleanup event at a site
model CleanupEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title       String
  description String           @db.Text
  category    EcoEventCategory @default(GENERAL_CLEANUP)

  scheduledAt             DateTime
  endAt                   DateTime?
  /// When set to the same instant as [endAt], the organizer "cleanup ending soon" push was sent for that end time. Cleared when [endAt] changes (extension).
  endSoonNotifiedForEndAt DateTime?
  completedAt             DateTime?

  /// Moderation (admin approval for user-created events).
  status CleanupEventStatus @default(APPROVED)

  /// Lifecycle shown in the mobile app when event is APPROVED.
  lifecycleStatus EcoEventLifecycleStatus @default(UPCOMING)

  organizerId String?
  organizer   User?   @relation("CleanupEventOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)

  participantCount Int @default(0)

  gear            String[]            @default([])
  scale           EcoCleanupScale?
  difficulty      EcoEventDifficulty?
  afterImageKeys  String[]            @default([])
  maxParticipants Int?

  /// Rotates when organizer opens check-in or taps rotate; invalidates old QR tokens.
  checkInSessionId String?
  checkInOpen      Boolean @default(false)
  /// Denormalized count of [EventCheckIn] rows for this event.
  checkedInCount   Int     @default(0)

  participants       EventParticipant[]
  checkIns           EventCheckIn[]
  checkInRedemptions EventCheckInRedemption[]
  chatMessages       EventChatMessage[]
  chatReadCursors    EventChatReadCursor[]
  chatMutes          EventChatMute[]
  liveMetric         EventLiveMetric?
  evidencePhotos     EventEvidencePhoto[]
  routeSegments      EventRouteSegment[]
  checkInRiskSignals CheckInRiskSignal[]

  /// RFC 5545 RRULE string (e.g. FREQ=WEEKLY;COUNT=8;BYDAY=SA).
  /// Null for non-recurring events.
  recurrenceRule String?

  /// References the first event in a recurring series. Null for standalone/parent events.
  parentEventId  String?
  parentEvent    CleanupEvent?  @relation("RecurrenceSeries", fields: [parentEventId], references: [id], onDelete: SetNull)
  seriesChildren CleanupEvent[] @relation("RecurrenceSeries")

  /// 0-based index within its series (0 = original/parent). Null for non-recurring.
  recurrenceIndex Int?

  @@index([siteId])
  @@index([scheduledAt])
  @@index([siteId, scheduledAt])
  @@index([status])
  @@index([lifecycleStatus, scheduledAt])
  @@index([lifecycleStatus, endAt])
  @@index([organizerId])
  @@index([parentEventId])
}

enum EventChatMessageType {
  TEXT
  SYSTEM
  IMAGE
  LOCATION
  VIDEO
  AUDIO
  FILE
}

model EventParticipant {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reminderEnabled Boolean   @default(false)
  reminderAt      DateTime?

  @@unique([eventId, userId])
  @@index([eventId, joinedAt])
  @@index([userId])
}

/// Text or system message in an event participant chat (organizer + joiners).
model EventChatMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("EventChatMessages", fields: [authorId], references: [id], onDelete: Cascade)

  body String @db.Text

  replyToId String?
  replyTo   EventChatMessage?  @relation("ChatReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   EventChatMessage[] @relation("ChatReplies")

  deletedAt DateTime?

  editedAt DateTime?

  isPinned   Boolean   @default(false)
  pinnedAt   DateTime?
  pinnedById String?
  pinnedBy   User?     @relation("EventChatPinnedBy", fields: [pinnedById], references: [id], onDelete: SetNull)

  messageType   EventChatMessageType @default(TEXT)
  systemPayload Json?

  locationLat   Float?
  locationLng   Float?
  locationLabel String?

  bodyEncrypted Boolean @default(false)

  /// Client-generated UUID for idempotent sends (POST retry / offline flush).
  clientMessageId String?

  attachments EventChatAttachment[]

  readCursorsLastRead EventChatReadCursor[] @relation("ReadCursorLastMessage")

  @@unique([eventId, clientMessageId])
  @@index([eventId, createdAt])
  @@index([authorId])
  @@index([eventId, isPinned, pinnedAt])
}

model EventChatAttachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  messageId String
  message   EventChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  url          String
  mimeType     String
  fileName     String
  sizeBytes    Int
  width        Int?
  height       Int?
  duration     Int?
  thumbnailUrl String?

  @@index([messageId])
}

/// Per-user mute for event chat push notifications (SSE still delivers).
model EventChatMute {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("EventChatMutes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

/// Per-user read position for event chat unread counts.
model EventChatReadCursor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("EventChatReadCursors", fields: [userId], references: [id], onDelete: Cascade)

  lastReadMessageId String?
  lastReadMessage   EventChatMessage? @relation("ReadCursorLastMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId])
  @@index([userId])
}

/// Attendee check-in at an event (registered user or manual guest list).
model EventCheckIn {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  /// `u:<userId>` for app users, `g:<slug>` for manual guest rows (normalized name).
  dedupeKey String

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  guestDisplayName String?

  checkedInAt DateTime @default(now())

  @@unique([eventId, dedupeKey])
  @@index([eventId, checkedInAt])
  @@index([userId])
}

/// Single-use QR token ids (jti) — prevents screenshot replay across different users.
model EventCheckInRedemption {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  jti String @unique

  @@index([eventId])
}

/// Denormalized organizer-reported live counters (pulse); aggregates also read from [CleanupEvent].
model EventLiveMetric {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String       @unique
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  reportedBagsCollected Int @default(0)
}

enum EventEvidenceKind {
  BEFORE
  AFTER
  FIELD
}

model EventEvidencePhoto {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  kind         EventEvidenceKind
  objectKey    String
  caption      String?
  uploadedById String
  uploadedBy   User              @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([eventId, kind, createdAt])
}

enum RouteSegmentStatus {
  OPEN
  CLAIMED
  COMPLETED
}

model EventRouteSegment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sortOrder Int
  label     String?
  latitude  Float
  longitude Float

  status RouteSegmentStatus @default(OPEN)

  claimedByUserId String?
  claimedBy       User?     @relation("RouteSegmentClaims", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt       DateTime?
  completedAt     DateTime?

  @@index([eventId, sortOrder])
  @@index([claimedByUserId])
}

enum CheckInRiskSignalType {
  FAR_FROM_SITE
}

model CheckInRiskSignal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  expiresAt DateTime

  eventId String
  event   CleanupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signalType CheckInRiskSignalType
  metadata   Json?

  @@index([eventId, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt])
}

model SiteVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([userId, createdAt])
  @@index([siteId, createdAt])
}

model SiteSave {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([userId, createdAt])
  @@index([siteId, createdAt])
}

model SiteComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parentId String?
  parent   SiteComment?      @relation("SiteCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  SiteComment[]     @relation("SiteCommentReplies")
  likes    SiteCommentLike[]

  body       String
  isDeleted  Boolean @default(false)
  likesCount Int     @default(0)

  @@index([siteId, createdAt])
  @@index([siteId, parentId, createdAt])
  @@index([authorId, createdAt])
}

model SiteCommentLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  commentId String
  comment   SiteComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, createdAt])
  @@index([userId, createdAt])
}

enum SiteShareChannel {
  native
  link
  whatsapp
  facebook
  x
  other
}

model SiteShareEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channel SiteShareChannel @default(native)

  @@index([siteId, createdAt])
  @@index([userId, createdAt])
}

enum SiteShareAttributionEventType {
  CLICK
  OPEN
}

enum SiteShareAttributionSource {
  WEB
  APP
  OTHER
}

model SiteShareLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cid       String    @unique
  expiresAt DateTime
  countedAt DateTime?

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  sharedByUserId String?
  sharedByUser   User?   @relation(fields: [sharedByUserId], references: [id], onDelete: SetNull)

  channel SiteShareChannel @default(native)

  attributionEvents SiteShareAttributionEvent[]

  @@index([siteId, createdAt])
  @@index([sharedByUserId, createdAt])
  @@index([expiresAt])
}

model SiteShareAttributionEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  shareLinkId String
  shareLink   SiteShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)

  eventType SiteShareAttributionEventType
  source    SiteShareAttributionSource    @default(OTHER)
  dedupeKey String

  ipHash         String?
  userAgentHash  String?
  openedByUserId String?

  @@unique([shareLinkId, eventType, dedupeKey])
  @@index([shareLinkId, createdAt])
  @@index([eventType, createdAt])
}

model UserFeedState {
  userId             String    @id
  mutedCategoryIds   String[]  @default([])
  hiddenSiteIds      String[]  @default([])
  followReporterIds  String[]  @default([])
  engagementProfile  Json?
  recencyDecayFactor Float     @default(0)
  lastFeedAt         DateTime?
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SiteFeatureSnapshot {
  siteId          String    @id
  velocity1h      Float     @default(0)
  velocity6h      Float     @default(0)
  velocity24h     Float     @default(0)
  discussionRatio Float     @default(0)
  intentRatio     Float     @default(0)
  qualityScore    Float     @default(0)
  freshnessHours  Float     @default(0)
  severityIndex   Float     @default(0)
  verifiedAgeDays Int       @default(0)
  lastReportAt    DateTime?
  denormHash      String    @default("")
  updatedAt       DateTime  @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)
}

model FeedImpression {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  variant  String
  position Int?
  dwellMs  Int?
  engaged  Boolean @default(false)

  @@index([userId, createdAt])
  @@index([siteId, createdAt])
}

model FeedExperimentAssignment {
  userId        String
  experimentKey String
  variant       String
  assignedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, experimentKey])
}

enum DevicePlatform {
  IOS
  ANDROID
}

model UserDeviceToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String         @unique
  platform     DevicePlatform
  appVersion   String?
  locale       String?
  lastSeenAt   DateTime       @default(now())
  revokedAt    DateTime?
  failureCount Int            @default(0)

  @@index([userId, revokedAt])
  @@index([token])
}

enum NotificationType {
  SITE_UPDATE
  REPORT_STATUS
  UPVOTE
  COMMENT
  NEARBY_REPORT
  CLEANUP_EVENT
  EVENT_CHAT
  SYSTEM
}

model UserNotification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)
  data      Json?
  sentAt    DateTime?
  threadKey String?
  groupKey  String?

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([userId, groupKey, createdAt])
}

model UserNotificationPreference {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       NotificationType
  muted      Boolean          @default(false)
  mutedUntil DateTime?

  @@unique([userId, type])
  @@index([userId, muted])
}

model NotificationOutbox {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userNotificationId String
  deviceToken        String
  payload            Json
  attempts           Int       @default(0)
  nextRetryAt        DateTime?
  processingAt       DateTime?
  leaseOwner         String?
  lastAttemptAt      DateTime?
  lastErrorCode      String?
  lastErrorMessage   String?
  deliveredAt        DateTime?
  failedPermanently  Boolean   @default(false)
  idempotencyKey     String    @unique

  @@index([deliveredAt, failedPermanently, attempts])
  @@index([processingAt, nextRetryAt])
  @@index([createdAt])
}

/// Records client-supplied job ids for idempotent admin bulk mutations (e.g. bulk approve/decline).
model AdminMutationIdempotency {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorUserId String
  purpose     String
  clientJobId String

  @@unique([actorUserId, purpose, clientJobId])
  @@index([createdAt])
  @@map("admin_mutation_idempotency")
}
