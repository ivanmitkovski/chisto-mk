<!DOCTYPE html>
<html lang="{{locale}}" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="x-apple-disable-message-reformatting" />
  <meta name="color-scheme" content="light dark" />
  <meta name="supported-color-schemes" content="light dark" />
  <title>{{preheader}}</title>
  <style type="text/css">
    @media screen {
      .cm-cta:hover { background-color: {{ctaHoverBg}} !important; }
    }
    @media (prefers-color-scheme: dark) {
      .cm-body { background-color: #1a1c1f !important; }
      .cm-card { background-color: #24262b !important; border-color: #3a3d45 !important; }
      .cm-text { color: #e8e8ea !important; }
      .cm-muted { color: #a8a8b0 !important; }
      .cm-detail { background-color: #2c2f36 !important; border-color: #3a3d45 !important; }
    }
  </style>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
</head>
<body class="cm-body" style="margin:0;padding:0;background-color:{{brandAppBackground}};font-family:{{brandFontStack}};">
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">{{preheader}}&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;</div>
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="cm-body" style="background-color:{{brandAppBackground}};">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" class="cm-card" style="max-width:600px;background-color:{{brandPanel}};border-radius:16px;border:1px solid {{brandDivider}};">
          {{#if showAccentBar}}
          <tr>
            <td height="4" bgcolor="{{accentHex}}" style="line-height:4px;font-size:0;mso-line-height-rule:exactly;border-radius:16px 16px 0 0;">&nbsp;</td>
          </tr>
          {{/if}}
          <tr>
            <td style="padding:24px {{innerPadX}} 8px {{innerPadX}};">
              {{#if logoUrl}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding:0 0 12px 0;">
                    <img src="{{{logoUrl}}}" width="140" height="auto" alt="Chisto.mk" style="display:block;border:0;outline:none;text-decoration:none;height:auto;max-width:140px;" />
                  </td>
                </tr>
              </table>
              {{/if}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="cm-text" style="font-size:22px;font-weight:700;letter-spacing:-0.3px;color:{{brandTextPrimary}};">
                    Chisto<span style="color:{{brandPrimary}};">.mk</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:8px {{innerPadX}} 8px {{innerPadX}};">
              <h1 class="cm-text" style="margin:0;font-size:26px;font-weight:600;letter-spacing:-0.2px;line-height:1.2;color:{{brandTextPrimary}};">{{headline}}</h1>
            </td>
          </tr>
          <tr>
            <td class="cm-muted" style="padding:8px {{innerPadX}} 24px {{innerPadX}};font-size:16px;line-height:1.45;color:{{brandTextSecondary}};">
              {{{bodyHtml}}}
            </td>
          </tr>
          {{#if ctaUrl}}
          <tr>
            <td style="padding:0 {{innerPadX}} 28px {{innerPadX}};">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="left">
                <tr>
                  <td align="center" bgcolor="{{ctaBg}}" style="border-radius:12px;mso-padding-alt:14px 28px;">
                    <!--[if mso]>
                    <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{{ctaUrl}}}" style="height:48px;v-text-anchor:middle;width:280px;" arcsize="13%" strokecolor="{{ctaBg}}" fillcolor="{{ctaBg}}">
                      <w:anchorlock/>
                      <center style="color:#ffffff;font-family:sans-serif;font-size:16px;font-weight:600;">{{ctaLabel}}</center>
                    </v:roundrect>
                    <![endif]-->
                    <!--[if !mso]><!-- -->
                    <a class="cm-cta" href="{{{ctaUrl}}}" target="_blank" rel="noopener noreferrer" style="display:inline-block;background-color:{{ctaBg}};color:#FFFFFF;text-decoration:none;font-size:16px;font-weight:600;line-height:48px;padding:0 28px;border-radius:12px;mso-hide:all;">{{ctaLabel}}</a>
                    <!--<![endif]-->
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {{/if}}
          <tr>
            <td style="padding:0 {{innerPadX}} 28px {{innerPadX}};border-top:1px solid {{brandDivider}};">
              <p class="cm-muted" style="margin:20px 0 8px 0;font-size:13px;line-height:1.45;color:{{brandTextMuted}};">
                Chisto.mk: civic environmental platform. You received this transactional email because of activity on your account.
              </p>
              <p class="cm-muted" style="margin:0;font-size:13px;line-height:1.45;color:{{brandTextMuted}};">
                <a href="{{{prefsUrl}}}" style="color:{{brandPrimaryDark}};text-decoration:underline;">Manage preferences</a>
                &nbsp;·&nbsp;
                <a href="{{{unsubscribeUrl}}}" style="color:{{brandPrimaryDark}};text-decoration:underline;">Unsubscribe from this type</a>
              </p>
              <p class="cm-muted" style="margin:16px 0 0 0;font-size:12px;color:{{brandTextMuted}};">© {{year}} Chisto.mk</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
