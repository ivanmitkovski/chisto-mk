<?xml version="1.0" encoding="utf-8"?>
<!-- Default-deny cleartext; allow only listed dev hosts. Production stays
     HTTPS-only (api-dev, api-staging, api.chisto.mk). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false"/>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Internal AWS dev ALB used by emulator builds during development. -->
        <domain includeSubdomains="true">elb.amazonaws.com</domain>
    </domain-config>
</network-security-config>
