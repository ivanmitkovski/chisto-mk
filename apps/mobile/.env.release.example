# Local prod release build overrides (copy to .env.release — gitignored).
# Used by ./scripts/build-prod.sh

# Crash reporting (recommended for store builds)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Android upload keystore (optional if ~/.chisto/android-signing.env exists).
# Must match the upload key registered in Play Console (Setup → App signing).
# Do NOT run setup-android-signing.sh if Play already has an upload key — use the original .jks.
# ANDROID_KEYSTORE_PATH=/path/to/original-upload.jks
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=
# PLAY_EXPECTED_UPLOAD_SHA1=AA:73:CC:8F:48:29:B0:E3:46:15:3B:85:FF:AE:71:73:00:D1:35:38
