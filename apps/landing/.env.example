# Public site URL (canonical). On Vercel you can omit if you rely on VERCEL_URL in code.
NEXT_PUBLIC_SITE_URL=https://chisto.mk

# Data & account requests — email (e.g. privacy@chisto.mk) or https URL shown on /data
NEXT_PUBLIC_DATA_REQUEST_URL=

# Legal copy placeholders (optional; tokens in messages stay until filled)
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_ENTITY_TYPE=
NEXT_PUBLIC_REGISTERED_ADDRESS=
NEXT_PUBLIC_REGISTRATION_NUMBER=
NEXT_PUBLIC_TAX_ID=
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=
# General/service contact (defaults to legal email if empty)
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_ADDRESS=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_PRIVACY_POLICY_URL=
# Full URLs for cross-links in legal copy (optional; otherwise [TERMS_URL] / [COOKIE_PREFERENCES_URL] stay as tokens)
NEXT_PUBLIC_TERMS_URL=
NEXT_PUBLIC_COOKIE_PREFERENCES_URL=
NEXT_PUBLIC_PRIVACY_EMAIL=
NEXT_PUBLIC_COOKIE_POLICY_URL=
# Optional — cookie table / marketing disclosures
NEXT_PUBLIC_AD_COOKIE_NAME=
NEXT_PUBLIC_AD_PROVIDER=
NEXT_PUBLIC_AD_PURPOSE=
NEXT_PUBLIC_HOSTING_PROVIDER=
NEXT_PUBLIC_SERVER_LOCATION=
NEXT_PUBLIC_SERVER_COUNTRY_OR_REGION=
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_PAYMENT_PROCESSOR=
NEXT_PUBLIC_EMAIL_PROVIDER=
NEXT_PUBLIC_SUPPORT_PROVIDER=
NEXT_PUBLIC_MAP_PROVIDER=
NEXT_PUBLIC_SUPERVISORY_AUTHORITY_ADDRESS=
NEXT_PUBLIC_SUPERVISORY_AUTHORITY_PHONE=
NEXT_PUBLIC_AUTHORITY_ADDRESS=
NEXT_PUBLIC_LIABILITY_CAP_EUR=
NEXT_PUBLIC_COURT_LOCATION=
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=
# Shown on legal pages when messages use [DATE] (e.g. terms last updated)
NEXT_PUBLIC_LEGAL_LAST_UPDATED_DATE=
NEXT_PUBLIC_DPO_EMAIL=
# GDPR Art. 27 EU representative (name, address, email) — single line or use BLOCK below
NEXT_PUBLIC_EU_REPRESENTATIVE=
NEXT_PUBLIC_EU_REPRESENTATIVE_BLOCK=
NEXT_PUBLIC_SUPERVISORY_AUTHORITY_NAME=
NEXT_PUBLIC_GOVERNING_LAW_JURISDICTION=
NEXT_PUBLIC_RETENTION_CONTACT_MONTHS=
NEXT_PUBLIC_RETENTION_LOGS_MONTHS=
NEXT_PUBLIC_DISPUTE_RESOLUTION_BLOCK=
NEXT_PUBLIC_DISPUTE_RESOLUTION_MECHANISM=
NEXT_PUBLIC_SDK_PURPOSE_BLOCK=
NEXT_PUBLIC_OTHER_SDK_NAME=
NEXT_PUBLIC_OTHER_SDK_PURPOSE=
NEXT_PUBLIC_TRACKING_STATUS_BLOCK=
NEXT_PUBLIC_TRACKING_STATUS=
NEXT_PUBLIC_US_PRIVACY_REQUEST_URL=

# Resend — newsletter + contact form (server only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_NOTIFY_TO=
