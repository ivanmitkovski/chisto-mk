# Resend — newsletter + contact form (server only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@ekohab.mk
RESEND_NOTIFY_TO=info@ekohab.mk

# On-demand ISR revalidation from the API (server only; must match API LANDING_REVALIDATE_SECRET)
LANDING_REVALIDATE_SECRET=

