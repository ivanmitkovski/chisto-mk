# Chisto.mk Landing — environment template
# Copy to .env.local for local dev, or set in the hosting provider (e.g. Vercel) project settings.
# NEXT_PUBLIC_* values are inlined at build time — redeploy after changing.

# Public API origin used by event share pages (/events/[id]). Origin only.
# Example: https://api.chisto.mk
NEXT_PUBLIC_CHISTO_API_URL=https://api.chisto.mk

# Canonical public site URL (no trailing slash). Used for canonical/OG links.
# Example: https://chisto.mk
NEXT_PUBLIC_CHISTO_SITE_URL=https://chisto.mk

# --- Waitlist storage (optional; server-only) ---
# Supabase project for landing waitlist signups. When unset, signups fall back to an in-memory store.
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS — keep server-only, never expose to the client.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
