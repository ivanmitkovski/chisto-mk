# Public site URL (canonical). On Vercel you can omit if you rely on VERCEL_URL in code.
NEXT_PUBLIC_SITE_URL=https://chisto.mk

# Public app and social links. Leave empty until live; empty values hide those CTAs.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_GOOGLE_PLAY_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# Data & account requests — email (e.g. privacy@chisto.mk) or https URL shown on /data
NEXT_PUBLIC_DATA_REQUEST_URL=info@ekohab.mk

# Legal copy placeholders (optional; tokens in messages stay until filled)
NEXT_PUBLIC_LEGAL_ENTITY_NAME=Здружение за животна средина ЕКОХАБ Скопје
NEXT_PUBLIC_ENTITY_TYPE=citizens' environmental association
NEXT_PUBLIC_REGISTERED_ADDRESS=ул. Сава Михајлов 2 бр.15, Скопје - Гази Баба, Република Северна Македонија
NEXT_PUBLIC_REGISTRATION_NUMBER=7939248
NEXT_PUBLIC_TAX_ID=4043026544136
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=info@ekohab.mk
# General/service contact (defaults to legal email if empty)
NEXT_PUBLIC_CONTACT_EMAIL=info@ekohab.mk
NEXT_PUBLIC_CONTACT_ADDRESS=Скопје, Република Северна Македонија
NEXT_PUBLIC_CONTACT_PHONE=+389 75 770 803
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://chisto.mk/privacy
# Full URLs for cross-links in legal copy (optional; otherwise [TERMS_URL] / [COOKIE_PREFERENCES_URL] stay as tokens)
NEXT_PUBLIC_TERMS_URL=https://chisto.mk/terms
NEXT_PUBLIC_COOKIE_PREFERENCES_URL=https://chisto.mk/cookies#settings
NEXT_PUBLIC_PRIVACY_EMAIL=info@ekohab.mk
NEXT_PUBLIC_COOKIE_POLICY_URL=https://chisto.mk/cookies
# Optional — cookie table / marketing disclosures
NEXT_PUBLIC_AD_COOKIE_NAME=Not used
NEXT_PUBLIC_AD_PROVIDER=Not used
NEXT_PUBLIC_AD_PURPOSE=Not used
NEXT_PUBLIC_HOSTING_PROVIDER=Amazon Web Services (AWS)
NEXT_PUBLIC_SERVER_LOCATION=AWS eu-central-1 (Frankfurt, Germany)
NEXT_PUBLIC_SERVER_COUNTRY_OR_REGION=European Union / EEA
NEXT_PUBLIC_ANALYTICS_PROVIDER=Firebase Analytics and Firebase Crashlytics in the mobile apps; optional Vercel Web Analytics on the website
NEXT_PUBLIC_PAYMENT_PROCESSOR=Not used in the current product
NEXT_PUBLIC_EMAIL_PROVIDER=Resend for website contact and update notifications; Mailchimp only if newsletters are enabled later
NEXT_PUBLIC_SUPPORT_PROVIDER=Email support at info@ekohab.mk
NEXT_PUBLIC_MAP_PROVIDER=CARTO basemaps using OpenStreetMap data, with Esri World Imagery where satellite maps are offered
NEXT_PUBLIC_SUPERVISORY_AUTHORITY_ADDRESS=Boulevard Goce Delchev 18, Skopje, Republic of North Macedonia
NEXT_PUBLIC_SUPERVISORY_AUTHORITY_PHONE=+389 2 3230 635
NEXT_PUBLIC_AUTHORITY_ADDRESS=Boulevard Goce Delchev 18, Skopje, Republic of North Macedonia
NEXT_PUBLIC_LIABILITY_CAP_EUR=100
NEXT_PUBLIC_COURT_LOCATION=Skopje
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=29 April 2026
# Shown on legal pages when messages use [DATE] (e.g. terms last updated)
NEXT_PUBLIC_LEGAL_LAST_UPDATED_DATE=30 April 2026
NEXT_PUBLIC_DPO_EMAIL=Not appointed
# GDPR Art. 27 EU representative (name, address, email) — single line or use BLOCK below
NEXT_PUBLIC_EU_REPRESENTATIVE=Not applicable
NEXT_PUBLIC_EU_REPRESENTATIVE_BLOCK=Not applicable
NEXT_PUBLIC_SUPERVISORY_AUTHORITY_NAME=Agency for Personal Data Protection of the Republic of North Macedonia
NEXT_PUBLIC_GOVERNING_LAW_JURISDICTION=Republic of North Macedonia
NEXT_PUBLIC_RETENTION_CONTACT_MONTHS=90 days
NEXT_PUBLIC_RETENTION_LOGS_MONTHS=90 days
NEXT_PUBLIC_DISPUTE_RESOLUTION_BLOCK=Amicable resolution first, then the competent courts in Skopje, Republic of North Macedonia.
NEXT_PUBLIC_DISPUTE_RESOLUTION_MECHANISM=competent courts in Skopje, Republic of North Macedonia
NEXT_PUBLIC_SDK_PURPOSE_BLOCK=AWS hosts the service infrastructure; Twilio delivers SMS verification messages; Firebase Cloud Messaging delivers push notifications; Firebase Analytics and Crashlytics provide app analytics and crash diagnostics; Resend delivers website contact and update notification emails; Mailchimp may send newsletters only if enabled later.
NEXT_PUBLIC_OTHER_SDK_NAME=Firebase Analytics and Crashlytics
NEXT_PUBLIC_OTHER_SDK_PURPOSE=App analytics and crash diagnostics
NEXT_PUBLIC_TRACKING_STATUS_BLOCK=We do not use IDFA and do not track users across third-party apps or websites for advertising.
NEXT_PUBLIC_TRACKING_STATUS=We do not use IDFA and do not track users across third-party apps or websites for advertising.
NEXT_PUBLIC_US_PRIVACY_REQUEST_URL=mailto:info@ekohab.mk

# Resend — newsletter + contact form (server only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@ekohab.mk
RESEND_NOTIFY_TO=info@ekohab.mk
