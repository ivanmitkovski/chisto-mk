# Public site URL (canonical). On Vercel you can omit if you rely on VERCEL_URL in code.
NEXT_PUBLIC_SITE_URL=https://chisto.mk

# Share landing pages — API base MUST include the /v1 global prefix.
NEXT_PUBLIC_CHISTO_API_URL=https://api.chisto.mk/v1
NEXT_PUBLIC_CHISTO_SITE_URL=https://chisto.mk

# Public app and social links. App Store is live (MK storefront — listing is Macedonia only).
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/mk/app/chisto-mk/id6771892086
# Google Play is live (package mk.chisto.app).
NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=mk.chisto.app
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/profile.php?id=61590541866009
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/chisto.mk/
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/chisto-mk/

# Data & account requests — email (e.g. privacy@chisto.mk) or https URL shown on /data
NEXT_PUBLIC_DATA_REQUEST_URL=info@ekohab.mk

# Legal copy placeholders (optional; tokens in messages stay until filled)
NEXT_PUBLIC_LEGAL_ENTITY_NAME=Здружение за животна средина ЕКОХАБ Скопје
