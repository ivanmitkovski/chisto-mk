NEXT_PUBLIC_CONTACT_PHONE=+389 75 770 803
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://chisto.mk/mk/privacy
# Full URLs for cross-links in legal copy (optional; locale-prefixed defaults are built at runtime)
