# Chisto.mk Admin — Vercel / deployment
# Copy to .env.local for local dev, or set in Vercel project settings.

# Canonical admin site URL (metadataBase, Open Graph). Use your deployed admin origin, no trailing slash.
# Example: https://admin.chisto.mk
NEXT_PUBLIC_ADMIN_SITE_URL=

# API base URL (required for production). Used for auth, data fetching, and CSP connect-src.
# Inlined at build time — redeploy after changing.
# Origin only — /v1 is appended automatically for API routes
NEXT_PUBLIC_API_BASE_URL=https://api.chisto.mk

# Optional: same origin as NEXT_PUBLIC_API_BASE_URL, but read at runtime on the server/Edge only.
# Use in Vercel if a past build baked the wrong NEXT_PUBLIC value and RSC cannot reach the API.
# SERVER_API_BASE_URL=https://api.chisto.mk

# Optional: S3 media host for report images (defaults to chisto-dev-media if unset)
# NEXT_PUBLIC_S3_MEDIA_HOST=chisto-prod-media.s3.eu-central-1.amazonaws.com

# Optional: server-only API base (runtime). Alias of SERVER_API_BASE_URL; same origin as NEXT_PUBLIC_API_BASE_URL.
# API_BASE_URL=https://api.chisto.mk

# Optional: emit Content-Security-Policy-Report-Only alongside the enforced CSP (set to 1 to enable).
# ADMIN_STRICT_CSP_REPORT_ONLY=1

# Optional ops: temporary diagnostics key. When set, GET /api/diag/backend?key=... reports API reachability.
# ADMIN_DIAG_KEY=

# Optional: Upstash Redis (REST) for admin mutation rate-limiting. Falls back to in-memory when unset.
# Use a hash of the access token in the key if enabling in shared environments.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Aliases also accepted: REDIS_REST_URL / REDIS_REST_TOKEN
