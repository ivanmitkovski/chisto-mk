{
  "name": "@chisto/admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:structure": "node ../../scripts/check-admin-structure.mjs && node ../../scripts/check-admin-tokens.mjs && ADMIN_STYLES_ENFORCE_FEATURE_HEX=1 node ../../scripts/check-admin-styles.mjs && node scripts/check-admin-i18n.mjs && node scripts/check-admin-i18n-scopes.mjs && node scripts/check-admin-i18n-routes.mjs",
    "test:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "test:perf": "playwright test -c playwright.config.cjs tests/perf --workers=1",
    "test:watch": "vitest",
    "test:a11y": "playwright test -c playwright.config.cjs tests/a11y --workers=1",
    "test:smoke": "playwright test -c playwright.config.cjs tests/smoke --workers=1"
  },
  "dependencies": {
    "@chisto/api-client": "workspace:*",
    "@chisto/map-contracts": "workspace:*",
    "@chisto/news-content": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tanstack/react-query": "^5.95.2",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-link": "^2.26.1",
    "@tiptap/extension-placeholder": "^2.26.1",
    "@tiptap/extension-underline": "^2.26.1",
    "@tiptap/pm": "^2.26.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^2.26.1",
    "@types/leaflet": "^1.9.21",
    "framer-motion": "^12.34.3",
    "isomorphic-dompurify": "2.26.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.575.0",
    "next": "^15.5.18",
    "next-intl": "^4.13.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "recharts": "^3.8.0",
    "server-only": "0.0.1",
    "use-intl": "^4.13.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.3",
    "@next/bundle-analyzer": "15.5.18",
    "@next/env": "15.5.18",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
