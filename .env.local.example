# Chisto.mk — Local development environment
# Copy to .env for local use only.

DATABASE_URL="postgresql://chisto:chisto@localhost:5432/chisto"

# Admin/Landing: API base URL (defaults to http://localhost:3000 if unset)
# NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
PORT=3000
JWT_SECRET="replace-with-long-random-secret"
# Access token TTL in seconds. 900=15min (prod). Use 28800 (8h) or 86400 (24h) for dev to avoid frequent logouts.
JWT_ACCESS_EXPIRES_IN=28800
JWT_REFRESH_EXPIRES_DAYS=30
