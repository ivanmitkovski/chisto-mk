{
  "name": "@chisto/news-content",
  "version": "0.1.0",
  "private": true,
  "description": "Shared news body block types, sanitization, and rendering",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./sanitize": {
      "types": "./src/sanitize/index.ts",
      "import": "./src/sanitize/index.ts",
      "require": "./dist/sanitize/index.js",
      "default": "./src/sanitize/index.ts"
    },
    "./render": "./src/render/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "sanitize-html": "^2.17.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/sanitize-html": "^2.16.1",
    "@types/react": "^19.0.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
